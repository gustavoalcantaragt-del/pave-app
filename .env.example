# PAVE — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env no Git.

# Supabase (encontre em: Project Settings → API)
SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=sua_anon_key_aqui

# URL da aplicação (sem barra no final)
APP_URL=http://localhost:3000

# GitHub PAT (apenas para CI/CD — não vai para o frontend)
GITHUB_PAT=ghp_seuTokenAqui
